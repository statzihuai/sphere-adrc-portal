# SPHERE backend — copy to .env and fill in. Load with: uvicorn ... --env-file .env
# (The test suite needs NONE of these — WorkOS is mocked; see README.)

SPHERE_APP_ENV=development
SPHERE_DATABASE_URL=sqlite+aiosqlite:///./sphere.db
# SPHERE_CORS_ORIGINS=http://localhost:8000,https://web.stanford.edu

# WorkOS AuthKit (test mode) — from the WorkOS dashboard.
# Without these, /auth/* return 503 but the rest of the app runs.
WORKOS_API_KEY=sk_test_xxx
WORKOS_CLIENT_ID=client_xxx
WORKOS_REDIRECT_URI=http://localhost:8000/auth/callback
